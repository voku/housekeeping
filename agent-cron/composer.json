{
    "name": "voku/housekeeping-agent-cron",
    "description": "Standalone Symfony Console housekeeping cron runner.",
    "type": "project",
    "require": {
        "php": "^8.2",
        "symfony/console": "^7.4",
        "symfony/lock": "^7.4",
        "symfony/filesystem": "^7.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "HousekeepingAgentCron\\\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HousekeepingAgentCron\\\\Tests\\\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse --level=max src tests",
        "test": "phpunit"
    },
    "authors": [
        {
            "name": "voku",
            "email": "noreply@example.com"
        }
    ]
}
